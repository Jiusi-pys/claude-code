{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Feature-dev Evidence Ledger hooks for session management and validation",
  "hooks": [
    {
      "event": "SessionStart",
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": "mkdir -p \"${CLAUDE_PROJECT_DIR}/.claude/evidence/sessions\" 2>/dev/null || true",
          "timeout": 5000
        }
      ]
    }
  ]
}
