{
  "description": "Feature-dev Evidence Ledger hooks for session management",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"${CLAUDE_PROJECT_DIR}/.claude/evidence/sessions\" 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
